{
  "name": "ananke-commander",
  "version": "0.1.0",
  "description": "Ananke Commander — workspace-oriented desktop shell with dual-pane files, terminals, browser panes, and notes.",
  "author": "Ananke",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:app": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "postinstall": "CXXFLAGS=\"-isystem $(xcrun --show-sdk-path)/usr/include/c++/v1\" electron-rebuild -f -w node-pty || true"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "archiver": "^7.0.1",
    "d3-hierarchy": "^3.1.2",
    "electron-store": "^10.0.0",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "smol-toml": "^1.6.1",
    "tar": "^7.4.3",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/archiver": "^6.0.3",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.ananke.commander",
    "productName": "Ananke Commander",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    }
  }
}
